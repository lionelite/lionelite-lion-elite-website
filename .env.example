# Lion Elite Wellness rep portal
# Never commit real credentials or private rep data.

# Long random secret used to sign secure rep login cookies.
REP_PORTAL_SECRET=replace-with-a-long-random-secret

# JSON array of rep login accounts.
# Example only:
# [{"id":"rep-001","name":"Example Rep","email":"rep@example.com","password":"replace-me","referralCode":"EXAMPLE20"}]
REP_PORTAL_USERS_JSON=[]

# JSON object keyed by rep ID. This is the temporary data adapter until the
# order/affiliate backend is connected directly.
# Example only:
# {"rep-001":{"totalSales":0,"totalCommission":0,"pendingCommission":0,"paidCommission":0,"clicks":0,"conversions":0,"orders":[]}}
REP_PORTAL_DATA_JSON={}
